<%- include('../layouts/header') %>

<div class="mb-6">
  <h1 class="text-2xl font-bold tracking-tight text-slate-800">Stock Movement History</h1>
  <p class="text-sm text-slate-500 mt-1">Audit ledger, financial margins, velocity aggregations, and combined stock performance records.</p>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 mb-6">
  <form method="GET" action="/stock" class="flex flex-col lg:flex-row items-end gap-4">
    
    <div class="w-full lg:flex-1 min-w-[200px]">
      <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Search Catalog Product</label>
      <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
          <i class="fas fa-search text-xs"></i>
        </span>
        <input 
          type="text" 
          name="search" 
          value="<%= search %>"
          placeholder="Type product name..."
          class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg pl-9 pr-3 py-1.5 text-sm focus:outline-none focus:border-brand-teal transition duration-150"
        >
      </div>
    </div>

    <div class="w-full sm:w-auto flex-1 min-w-[150px]">
      <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Single Target Day</label>
      <input 
        type="date" 
        name="date" 
        value="<%= date || '' %>"
        class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-brand-teal transition duration-150"
      >
    </div>

    <div class="w-full sm:w-auto flex-1 min-w-[150px]">
      <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Origin (From)</label>
      <input 
        type="date" 
        name="from" 
        value="<%= from || '' %>"
        class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-brand-teal transition duration-150"
      >
    </div>

    <div class="w-full sm:w-auto flex-1 min-w-[150px]">
      <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">Terminal (To)</label>
      <input 
        type="date" 
        name="to" 
        value="<%= to || '' %>"
        class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-brand-teal transition duration-150"
      >
    </div>

    <div class="w-full lg:w-auto flex items-center gap-2 shrink-0 pt-2 lg:pt-0">
      <button 
        type="submit"
        class="flex-1 lg:flex-none inline-flex items-center justify-center gap-2 px-5 py-2 bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold rounded-lg transition duration-150 shadow-sm whitespace-nowrap"
      >
        <i class="fas fa-sliders-h text-xs text-slate-400"></i> Apply Filters
      </button>

      <a 
        href="/stock" 
        class="inline-flex items-center justify-center px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-500 hover:text-slate-700 text-sm font-semibold rounded-lg border border-slate-200 transition duration-150"
      >
        Reset
      </a>
    </div>

  </form>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
  
  <div class="bg-white rounded-xl border border-slate-200 p-4 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total Sales Revenue</p>
      <h2 class="text-xl font-mono font-black text-slate-800 mt-1">
        TSh <%= Number(totalSales || 0).toLocaleString() %>
      </h2>
    </div>
    <div class="text-brand-teal bg-teal-50/60 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">
      <i class="fas fa-cash-register text-base"></i>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Calculated Profit</p>
      <h2 class="text-xl font-mono font-black text-emerald-600 mt-1">
        TSh <%= Number(totalProfit || 0).toLocaleString() %>
      </h2>
    </div>
    <div class="text-emerald-500 bg-emerald-50 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">
      <i class="fas fa-wallet text-base"></i>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Filtered Ledger Rows</p>
      <h2 class="text-xl font-mono font-black text-slate-800 mt-1">
        <%= movements ? movements.length : 0 %>
      </h2>
    </div>
    <div class="text-slate-500 bg-slate-50 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">
      <i class="fas fa-stream text-base"></i>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Available Pages</p>
      <h2 class="text-xl font-mono font-black text-slate-800 mt-1">
        <%= totalPages || 1 %> <span class="text-xs font-sans font-normal text-slate-400">blocks</span>
      </h2>
    </div>
    <div class="text-amber-500 bg-amber-50/50 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">
      <i class="fas fa-layer-group text-base"></i>
    </div>
  </div>

</div>

<div class="flex flex-col xl:flex-row gap-6 items-start mb-6">
  
  <div class="w-full xl:w-80 shrink-0 bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-100 bg-slate-50/50 flex items-center gap-2">
      <div class="w-1.5 h-1.5 rounded-full bg-brand-gold"></div>
      <h3 class="font-bold text-slate-800 text-xs tracking-wide uppercase">Daily Volume Velocity</h3>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse whitespace-nowrap">
        <thead>
          <tr class="bg-slate-50/70 border-b border-slate-200 text-slate-400 text-[10px] font-bold uppercase tracking-wider">
            <th class="py-2.5 px-4">Date</th>
            <th class="py-2.5 px-2 text-center">Type</th>
            <th class="py-2.5 px-4 text-right">Sum Qty</th>
          </tr>
        </thead>
        <tbody class="text-xs divide-y divide-slate-100 text-slate-700">
          <% if (dailySummary && dailySummary.length > 0) { %>
            <% dailySummary.forEach(d => { %>
              <tr class="hover:bg-slate-50/40 transition duration-75">
                <td class="py-2.5 px-4 font-medium text-slate-600"><%= d.dataValues.date %></td>
                <td class="py-2.5 px-2 text-center">
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold font-mono uppercase <%= d.type === 'IN' ? 'bg-emerald-50 text-emerald-700' : 'bg-rose-50 text-rose-700' %>">
                    <%= d.type %>
                  </span>
                </td>
                <td class="py-2.5 px-4 text-right font-mono font-bold text-slate-800">
                  <%= d.dataValues.total_quantity %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="3" class="py-6 text-center text-xs italic text-slate-400">No velocity trends found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="flex-1 w-full bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
      <h3 class="font-bold text-slate-800 text-xs tracking-wide uppercase">Unified Operational & Margin Ledger</h3>
      <span class="text-[11px] font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded border border-slate-200/50 font-semibold">
        Active Viewport: <%= movements.length %> Records
      </span>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse whitespace-nowrap text-sm">
        <thead>
          <tr class="bg-slate-50/70 border-b border-slate-200 text-slate-400 text-[11px] font-bold uppercase tracking-wider">
            <th class="py-3.5 px-4">Timestamp</th>
            <th class="py-3.5 px-4">Product Description</th>
            <th class="py-3.5 px-2 text-center">Type</th>
            <th class="py-3.5 px-3 text-center">Qty</th>
            <th class="py-3.5 px-4 text-right">Gross Rev</th>
            <th class="py-3.5 px-4 text-right">Acquisition Cost</th>
            <th class="py-3.5 px-4 text-right">Net Profit</th>
            <th class="py-3.5 px-4 text-center">Margin</th>
            <th class="py-3.5 px-4 text-right">Ref Code</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700 text-xs">
          <% if (movements && movements.length > 0) { %>
            <% movements.forEach(m => { %>
              <tr class="hover:bg-slate-50/50 transition duration-150">
                
                <td class="py-3.5 px-4 text-slate-500 font-medium">
                  <%= new Date(m.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute:'2-digit' }) %>
                </td>
                
                <td class="py-3.5 px-4 font-semibold text-slate-800">
                  <%= m.Product ? m.Product.name : 'Unknown Catalog Item' %>
                </td>
                
                <td class="py-3.5 px-2 text-center">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold font-mono <%= m.type === 'IN' ? 'bg-emerald-50 text-emerald-700' : 'bg-rose-50 text-rose-700' %>">
                    <%= m.type %>
                  </span>
                </td>
                
                <td class="py-3.5 px-3 text-center font-mono font-bold">
                  <%= m.type === 'IN' ? '+' : '-' %><%= m.quantity %>
                </td>

                <% if (m.type === 'OUT' && m.Product) { %>
                  <% 
                    let lineRevenue = m.quantity * parseFloat(m.Product.sell_price || 0);
                    let lineCost = m.quantity * parseFloat(m.Product.buy_price || 0);
                    let lineProfit = lineRevenue - lineCost;
                    let marginPercent = lineRevenue > 0 ? ((lineProfit / lineRevenue) * 100).toFixed(1) : 0;
                  %>
                  <td class="py-3.5 px-4 text-right font-mono text-slate-700">TSh <%= lineRevenue.toLocaleString() %></td>
                  <td class="py-3.5 px-4 text-right font-mono text-slate-400">TSh <%= lineCost.toLocaleString() %></td>
                  <td class="py-3.5 px-4 text-right font-mono font-bold text-emerald-600 bg-emerald-50/20">
                    TSh <%= lineProfit.toLocaleString() %>
                  </td>
                  <td class="py-3.5 px-4 text-center font-mono font-bold text-emerald-700">
                    <%= marginPercent %>%
                  </td>
                <% } else if (m.type === 'IN' && m.Product) { %>
                  <% let restockCost = m.quantity * parseFloat(m.Product.buy_price || 0); %>
                  <td class="py-3.5 px-4 text-right text-slate-300 italic font-sans">—</td>
                  <td class="py-3.5 px-4 text-right font-mono text-amber-600 bg-amber-50/10">TSh <%= restockCost.toLocaleString() %></td>
                  <td class="py-3.5 px-4 text-right text-slate-300 italic font-sans">—</td>
                  <td class="py-3.5 px-4 text-center text-slate-300 italic font-sans">—</td>
                <% } else { %>
                  <td colspan="4" class="py-3.5 px-4 text-center text-slate-400 italic">Reference product details detached</td>
                <% } %>
                
                <td class="py-3.5 px-4 text-right font-mono text-[10px]">
                  <% if (m.reference) { %>
                    <span class="text-slate-600 bg-slate-100 border border-slate-200 px-1.5 py-0.5 rounded font-semibold"><%= m.reference %></span>
                  <% } else { %>
                    <span class="text-slate-400 italic font-sans">Internal Log</span>
                  <% } %>
                </td>

              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="9" class="py-12 text-center text-sm text-slate-400 italic">
                No matching operational or financial transaction rows found.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<% if (totalPages > 1) { %>
  <div class="flex justify-center items-center gap-1.5 mt-4 mb-8">
    
    <% if (currentPage > 1) { %>
      <a href="/stock?page=<%= Number(currentPage) - 1 %>&search=<%= search %>&date=<%= date || '' %>&from=<%= from || '' %>&to=<%= to || '' %>" class="px-3 py-1.5 bg-white border border-slate-200 text-slate-600 text-xs font-semibold rounded-lg hover:bg-slate-50 transition duration-150">
        <i class="fas fa-chevron-left"></i>
      </a>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <a 
        href="/stock?page=<%= i %>&search=<%= search %>&date=<%= date || '' %>&from=<%= from || '' %>&to=<%= to || '' %>"
        class="px-3.5 py-1.5 text-xs font-mono font-bold rounded-lg border transition duration-150
        <%= currentPage == i 
          ? 'bg-slate-800 border-slate-800 text-white shadow-sm' 
          : 'bg-white border-slate-200 text-slate-600 hover:bg-slate-50' %>"
      >
        <%= i %>
      </a>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="/stock?page=<%= Number(currentPage) + 1 %>&search=<%= search %>&date=<%= date || '' %>&from=<%= from || '' %>&to=<%= to || '' %>" class="px-3 py-1.5 bg-white border border-slate-200 text-slate-600 text-xs font-semibold rounded-lg hover:bg-slate-50 transition duration-150">
        <i class="fas fa-chevron-right"></i>
      </a>
    <% } %>

  </div>
<% } %>

<%- include('../layouts/footer') %>