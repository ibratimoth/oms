<%- include('../layouts/header') %>

<!-- Dashboard Title -->
<div class="mb-6">
  <h1 class="text-2xl font-bold tracking-tight text-slate-800">Dashboard Overview</h1>
  <p class="text-sm text-slate-500 mt-1">Real-time metrics and order management statistics.</p>
</div>

<!-- TOP METRICS GRID -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">

  <!-- PRODUCTS -->
  <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Total Products</p>
      <h3 class="text-2xl font-bold text-slate-800 mt-1"><%= totalProducts %></h3>
    </div>
    <div class="w-12 h-12 rounded-lg bg-teal-50 flex items-center justify-center text-brand-teal">
      <i class="fas fa-box text-xl"></i>
    </div>
  </div>

  <!-- TOTAL ORDERS -->
  <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Total Orders</p>
      <h3 class="text-2xl font-bold text-slate-800 mt-1"><%= totalOrders %></h3>
    </div>
    <div class="w-12 h-12 rounded-lg bg-amber-50 flex items-center justify-center text-brand-gold">
      <i class="fas fa-shopping-cart text-xl"></i>
    </div>
  </div>

  <!-- COMPLETED ORDERS -->
  <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Completed Orders</p>
      <h3 class="text-2xl font-bold text-emerald-600 mt-1"><%= completedOrders %></h3>
    </div>
    <div class="w-12 h-12 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
      <i class="fas fa-check-circle text-xl"></i>
    </div>
  </div>

  <!-- PENDING ORDERS -->
  <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Pending Orders</p>
      <h3 class="text-2xl font-bold text-amber-600 mt-1"><%= pendingOrders %></h3>
    </div>
    <div class="w-12 h-12 rounded-lg bg-amber-50/70 flex items-center justify-center text-amber-600">
      <i class="fas fa-clock text-xl"></i>
    </div>
  </div>

</div>

<!-- FINANCIAL PERFORMANCE CARD -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
  <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm flex items-center justify-between relative overflow-hidden ring-1 ring-brand-teal/5">
    <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-brand-teal/5 rounded-full"></div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Total Profit</p>
      <h3 class="text-2xl font-bold text-brand-teal mt-1"><%= totalProfit %></h3>
    </div>
    <div class="w-12 h-12 rounded-lg bg-brand-teal/10 flex items-center justify-center text-brand-teal relative z-10">
      <i class="fas fa-wallet text-xl"></i>
    </div>
  </div>
</div>

<!-- DUAL TABLES PANEL: LOW STOCK & RECENT ORDERS -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <!-- LOW STOCK SECTION -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col justify-between">
    <div>
      <div class="px-5 py-4 border-b border-slate-100 flex items-center gap-2.5">
        <div class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></div>
        <h3 class="font-bold text-slate-800 text-sm tracking-wide uppercase">Low Stock Alerts</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50 text-slate-400 text-xs font-bold uppercase tracking-wider border-b border-slate-100">
              <th class="py-3 px-5">Product Name</th>
              <th class="py-3 px-5 text-right">Available Stock</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-slate-100">
            <% if (lowStockProducts && lowStockProducts.length > 0) { %>
              <% lowStockProducts.forEach(p => { %>
                <tr class="hover:bg-slate-50/50 transition duration-150">
                  <td class="py-3.5 px-5 font-medium text-slate-700"><%= p.name %></td>
                  <td class="py-3.5 px-5 text-right">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-rose-50 text-rose-700 border border-rose-100">
                      <%= p.quantity_in_stock %> left
                    </span>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="2" class="py-6 text-center text-sm text-slate-400 italic">All items are sufficiently stocked.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- RECENT ORDERS SECTION -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col justify-between">
    <div>
      <div class="px-5 py-4 border-b border-slate-100 flex items-center gap-2">
        <i class="fas fa-history text-slate-400 text-xs"></i>
        <h3 class="font-bold text-slate-800 text-sm tracking-wide uppercase">Recent Orders</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50 text-slate-400 text-xs font-bold uppercase tracking-wider border-b border-slate-100">
              <th class="py-3 px-5">Order No</th>
              <th class="py-3 px-5">Status</th>
              <th class="py-3 px-5 text-right">Total Amount</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-slate-100">
            <% recentOrders.forEach(o => { %>
              <tr class="hover:bg-slate-50/50 transition duration-150">
                <td class="py-3.5 px-5 font-semibold text-slate-700">#<%= o.order_number %></td>
                <td class="py-3.5 px-5">
                  <% if (o.status === 'completed') { %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">
                      <span class="w-1 h-1 rounded-full bg-emerald-500 mr-1.5"></span> <%= o.status %>
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-100">
                      <span class="w-1 h-1 rounded-full bg-amber-500 mr-1.5"></span> <%= o.status %>
                    </span>
                  <% } %>
                </td>
                <td class="py-3.5 px-5 text-right font-medium text-slate-800"><%= o.total_amount %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<!-- DAILY SALES SUMMARY FULL WIDTH CARD -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden mb-4">
  <div class="px-5 py-4 border-b border-slate-100 flex items-center gap-2">
    <i class="fas fa-chart-line text-slate-400 text-sm"></i>
    <h3 class="font-bold text-slate-800 text-sm tracking-wide uppercase">Daily Sales Trends</h3>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 text-slate-400 text-xs font-bold uppercase tracking-wider border-b border-slate-100">
          <th class="py-3 px-6">Calendar Date</th>
          <th class="py-3 px-6 text-right">Gross Sales Volume</th>
        </tr>
      </thead>
      <tbody class="text-sm divide-y divide-slate-100">
        <% dailySales.forEach(d => { %>
          <tr class="hover:bg-slate-50/50 transition duration-150">
            <td class="py-3 px-6 text-slate-600 font-medium"><%= d.dataValues.date %></td>
            <td class="py-3 px-6 text-right font-bold text-slate-800">
              TSh <%= Number(d.dataValues.sales).toLocaleString() %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layouts/footer') %>