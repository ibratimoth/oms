      <div>
        &copy; 2026 <span class="font-semibold text-brand-teal">Delle Ventures</span>. All rights reserved.
      </div>
      <div class="text-slate-300 hidden sm:block">
        Order Management Portal
      </div>
    </footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
$(document).ready(function () {

  // Auto-focus barcode scanner input field
  $('#barcodeScannerInput').focus();
  
  // Keep focus on scanner box during idle clicks
  $(document).on('click', function(e) {
    if (!$(e.target).closest('input, select, .select2-container, button').length) {
      $('#barcodeScannerInput').focus();
    }
  });

  // 1. INITIALIZE SELECT2
  $('.product-select').select2();

  // 2. STOCK WARNINGS
  $(document).on('change', '.product-select', function () {
    const stock = $(this).find(':selected').data('stock');
    const reorder = $(this).find(':selected').data('reorder') || 5;
    const row = $(this).closest('.item-row');
    let warning = row.find('.stock-warning');

    if (warning.length === 0) {
      row.append('<small class="stock-warning text-xs font-semibold text-red-500 mt-1 block col-span-12"></small>');
      warning = row.find('.stock-warning');
    }

    if (stock !== undefined && stock <= reorder) {
      warning.text('⚠ Low stock: ' + stock);
    } else {
      warning.text('');
    }
  });

  // 3. CORE ROW GENERATOR
  function addProductRow(productId = null, qty = 1) {
    const container = document.getElementById('items');
    const currentIndex = $('.item-row').length; 
    const template = document.getElementById('productOptionsTemplate').innerHTML;

    const row = document.createElement('div');
    row.className = 'grid grid-cols-12 gap-3 mb-3 items-center item-row bg-slate-50 p-3 rounded-lg border border-slate-100';

    row.innerHTML = `
      <div class="col-span-12 md:col-span-6">
        <select name="items[${currentIndex}][product_id]" class="w-full bg-white border border-slate-300 rounded-lg py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal product-select">
          ${template}
        </select>
      </div>

      <div class="col-span-7 md:col-span-4">
        <div class="flex shadow-sm rounded-lg overflow-hidden bg-white">
          <button type="button" class="bg-red-50 hover:bg-red-100 text-red-600 font-bold px-3 py-2 text-sm border border-slate-200 transition duration-150" onclick="changeQty(this, -1)">-</button>
          
          <input type="number"
                 name="items[${currentIndex}][quantity]"
                 value="${qty}"
                 class="w-full border-y border-slate-200 text-center text-sm font-semibold text-slate-800 focus:outline-none qty-input">
          
          <button type="button" class="bg-green-50 hover:bg-green-100 text-green-600 font-bold px-3 py-2 text-sm border border-slate-200 transition duration-150" onclick="changeQty(this, 1)">+</button>
        </div>
      </div>

      <div class="col-span-5 md:col-span-2 text-right">
        <button type="button" class="btn-remove w-full md:w-auto inline-flex items-center justify-center gap-1 bg-white hover:bg-red-50 text-slate-400 hover:text-red-600 font-medium py-2 px-3 text-sm border border-slate-200 hover:border-red-200 rounded-lg shadow-sm transition duration-150">
          <i class="fas fa-trash-alt pointer-events-none text-xs mr-1"></i> Remove
        </button>
      </div>
    `;

    container.appendChild(row);

    const $select = $(row).find('.product-select');
    $select.select2();
    
    if (productId) {
      $select.val(productId).trigger('change');
    } else {
      $select.trigger('change');
    }
  }

  $('#addRow').on('click', function () {
    addProductRow();
  });

  // 4. HARDENED BARCODE PROCESSING ENGINE
  $('#barcodeScannerInput').on('keydown keypress', function (e) {
    if (e.keyCode === 13 || e.key === 'Enter') {
      e.preventDefault();
      e.stopPropagation();

      const inputField = $(this);
      const scannedCode = inputField.val().trim();
      
      if (!scannedCode) return false;

      let matchedProductId = null;

      // Scan through template items
      $('#productOptionsTemplate option').each(function () {
        const targetBarcode = String($(this).data('barcode') || '').trim();
        if (targetBarcode === scannedCode) {
          matchedProductId = $(this).val();
          return false; 
        }
      });

      if (matchedProductId) {
        let alreadyInCart = false;
        
        $('.item-row').each(function () {
          const currentSelect = $(this).find('.product-select');
          if (currentSelect.val() === matchedProductId) {
            const qtyInput = $(this).find('.qty-input');
            qtyInput.val(parseInt(qtyInput.val() || 0) + 1);
            alreadyInCart = true;
            return false; 
          }
        });

        if (!alreadyInCart) {
          const firstRow = $('.item-row').first();
          const firstSelect = firstRow.find('.product-select');
          const firstQty = firstRow.find('.qty-input');
          const templateFirstVal = $('#productOptionsTemplate option:first').val();

          if ($('.item-row').length === 1 && firstSelect.val() == templateFirstVal && firstQty.val() == 1) {
             firstSelect.val(matchedProductId).trigger('change');
          } else {
             addProductRow(matchedProductId, 1);
          }
        }
      } else {
        alert(`Product barcode "${scannedCode}" not registered in the system.`);
      }

      // Safe immediate text clearance 
      inputField.val('');
      
      // Secondary execution delay loop to cleanly swallow extra scanner characters
      setTimeout(function() {
        inputField.val('');
        inputField.focus();
      }, 30);

      return false;
    }
  });

  // Prevents the global form from submission handling if an unexpected enter event bubbles up
  $('#invoiceForm').on('submit', function(e) {
    if (document.activeElement.id === 'barcodeScannerInput') {
      e.preventDefault();
      return false;
    }
  });

  // 5. DELETION HANDLING
  $(document).on('click', '.btn-remove', function () {
    if ($('.item-row').length > 1) {
      $(this).closest('.item-row').remove();
    } else {
      alert('An order must contain at least one item line.');
    }
  });

});

function changeQty(btn, value) {
  const input = btn.parentNode.querySelector('.qty-input');
  let current = parseInt(input.value || 1);
  current += value;
  if (current < 1) current = 1;
  input.value = current;
}
</script>

<script src="">
  document.getElementById('addRow').addEventListener('click', function() {
  // Counts how many rows are on screen to dynamically assign the correct next index array pointer
  const index = document.querySelectorAll('.item-row').length; 
  
  const html = `
    <div class="grid grid-cols-12 gap-3 mb-3 items-center item-row bg-slate-50 p-3 rounded-lg border border-slate-100">
      <div class="col-span-12 md:col-span-6">
        <select name="items[${index}][product_id]" class="w-full bg-white border border-slate-300 rounded-lg py-2 px-3 text-sm product-select">
          <!-- Populate options via an identical clone or reference mapping -->
        </select>
      </div>
      <!-- Add matching dynamic quantity inputs & remove buttons mapping to index -->
    </div>`;
  
  document.getElementById('items').insertAdjacentHTML('beforeend', html);
});
</script>

<script>
  // Toggles the Mobile Hamburger Navigation Draw Window
  const mobileToggleBtn = document.getElementById('mobileSidebarToggle');
  const mainSidebarEl = document.getElementById('mainSidebar');
  const hamburgerIconEl = document.getElementById('hamburgerIcon');

  if (mobileToggleBtn && mainSidebarEl) {
    mobileToggleBtn.addEventListener('click', () => {
      // Toggle between hidden display and mobile fixed top layout values
      mainSidebarEl.classList.toggle('hidden');
      mainSidebarEl.classList.toggle('fixed');
      mainSidebarEl.classList.toggle('inset-y-0');
      mainSidebarEl.classList.toggle('right-0');
      
      // Swap font icons based on open or closed menu layout status
      if (mainSidebarEl.classList.contains('hidden')) {
        hamburgerIconEl.className = "fas fa-bars text-xl";
      } else {
        hamburgerIconEl.className = "fas fa-times text-xl";
      }
    });
  }

  // Toggles Nested Submenu Accordions Smoothly
  function toggleDropdownMenu(menuId, chevronId) {
    const activeSubmenu = document.getElementById(menuId);
    const targetChevron = document.getElementById(chevronId);
    
    if (activeSubmenu) {
      activeSubmenu.classList.toggle('hidden');
    }
    if (targetChevron) {
      targetChevron.classList.toggle('rotate-90');
    }
  }
</script>
</body>
</html>