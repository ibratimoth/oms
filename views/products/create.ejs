<%- include('../layouts/header') %>

<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<div class="mb-4">
  <a 
    href="/products" 
    class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-brand-teal transition duration-150 group"
  >
    <i class="fas fa-arrow-left text-xs group-hover:-translate-x-0.5 transition-transform duration-150"></i>
    <span>Back to Products List</span>
  </a>
</div>

<div class="mb-6">
  <h1 class="text-2xl font-bold tracking-tight text-slate-800">Add New Products</h1>
  <p class="text-sm text-slate-500 mt-1">Choose between adding a single manual catalog item or uploading an Excel sheet to save time.</p>
</div>

<div class="flex border-b border-slate-200 max-w-4xl mb-6">
  <button 
    id="tabSingleBtn" 
    onclick="switchMode('single')" 
    class="py-2.5 px-5 text-sm font-semibold border-b-2 border-brand-teal text-brand-teal transition-all duration-150 focus:outline-none"
  >
    <i class="fas fa-keyboard mr-2"></i>Single Product
  </button>
  <button 
    id="tabBulkBtn" 
    onclick="switchMode('bulk')" 
    class="py-2.5 px-5 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-all duration-150 focus:outline-none"
  >
    <i class="fas fa-file-excel mr-2"></i>Bulk Excel Import
  </button>
</div>

<div id="formSingleMode" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden max-w-4xl">
  
  <div class="h-1.5 bg-brand-teal w-full"></div>

  <form method="POST" action="/products/create" class="p-6 sm:p-8 space-y-6">
    
    <div>
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Basic Information</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        
        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Product Name</label>
          <input 
            type="text" 
            name="name" 
            required 
            class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 px-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
            placeholder="e.g., Enterprise Wireless Router"
          >
        </div>

        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Barcode / SKU</label>
          <input 
            type="text" 
            name="barcode" 
            class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 px-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
            placeholder="Scan barcode or type item SKU (Optional)"
          >
        </div>

      </div>
    </div>

    <div class="border-t border-slate-100 my-6"></div>

    <div>
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Pricing & Inventory Management</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-5">
        
        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Cost Price (Buy)</label>
          <div class="relative shadow-sm rounded-lg">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-xs font-semibold text-slate-400 bg-slate-100/80 border-r border-slate-200/60 rounded-l-lg px-2">
              TSh
            </span>
            <input 
              type="number" 
              step="0.01" 
              name="buy_price" 
              required 
              class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 pl-12 pr-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
              placeholder="0.00"
            >
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Selling Price</label>
          <div class="relative shadow-sm rounded-lg">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-xs font-semibold text-slate-400 bg-slate-100/80 border-r border-slate-200/60 rounded-l-lg px-2">
              TSh
            </span>
            <input 
              type="number" 
              step="0.01" 
              name="sell_price" 
              required 
              class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 pl-12 pr-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
              placeholder="0.00"
            >
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Initial Stock Qty</label>
          <input 
            type="number" 
            name="quantity_in_stock" 
            required 
            class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 px-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
            placeholder="0"
          >
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Low Stock Limit</label>
          <input 
            type="number" 
            name="reorder_level" 
            class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 px-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
            placeholder="5"
          >
        </div>

      </div>
    </div>

    <div class="pt-4 border-t border-slate-100 flex items-center justify-end gap-3">
      <a 
        href="/products" 
        class="px-4 py-2.5 text-sm font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg border border-slate-200 shadow-sm transition duration-150"
      >
        Cancel & Exit
      </a>
      <button 
        type="submit" 
        class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-brand-gold hover:bg-brand-goldHover text-white text-sm font-semibold rounded-lg shadow-sm transition duration-150"
      >
        <i class="fas fa-save text-xs"></i> Save Product
      </button>
    </div>

  </form>
</div>

<div id="formBulkMode" class="hidden bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden max-w-4xl">
  
  <div class="h-1.5 bg-emerald-500 w-full"></div>

  <div class="p-6 sm:p-8 space-y-6">
    
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 bg-slate-50 border border-slate-200 rounded-xl p-4">
      <div>
        <h4 class="text-sm font-bold text-slate-800">Missing an import spreadsheet blueprint?</h4>
        <p class="text-xs text-slate-500 mt-0.5">Download our pre-structured column pattern template ledger to populate your store inventory easily.</p>
      </div>
      <button 
        type="button"
        onclick="downloadExcelTemplate()"
        class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 text-xs font-bold rounded-lg shadow-sm transition duration-150 whitespace-nowrap"
      >
        <i class="fas fa-download text-emerald-600"></i> Download Excel Template
      </button>
    </div>

    <form method="POST" action="/products/bulk-upload" enctype="multipart/form-data" class="space-y-6">
      <div>
        <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Import Spreadsheet File</h3>
        <p class="text-xs text-slate-500 mb-4">
          Your excel sheet columns should include the headers: 
          <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-700 font-mono text-[11px]">Product Name</code>, 
          <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-700 font-mono text-[11px]">Barcode</code>, 
          <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-700 font-mono text-[11px]">Cost Price</code>, 
          <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-700 font-mono text-[11px]">Selling Price</code>, and 
          <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-700 font-mono text-[11px]">Initial Stock</code>.
        </p>
        
        <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center hover:border-emerald-500 transition duration-150 bg-slate-50/50">
          <i class="fas fa-cloud-upload-alt text-4xl text-slate-300 mb-3"></i>
          <label class="block cursor-pointer">
            <span class="bg-white px-3 py-1.5 border border-slate-200 rounded-lg shadow-sm text-xs font-semibold text-slate-600 hover:bg-slate-50">
              Choose Excel Document
            </span>
            <input 
              type="file" 
              name="excel_file" 
              accept=".xlsx, .xls" 
              required 
              class="hidden" 
              onchange="updateFileNameLabel(this)"
            >
          </label>
          <p id="fileNameDisplay" class="text-xs font-medium text-slate-500 mt-2.5">No spreadsheet selected (.xlsx or .xls only)</p>
        </div>
      </div>

      <div class="pt-4 border-t border-slate-100 flex items-center justify-end gap-3">
        <a 
          href="/products" 
          class="px-4 py-2.5 text-sm font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg border border-slate-200 shadow-sm transition duration-150"
        >
          Cancel
        </a>
        <button 
          type="submit" 
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg shadow-sm transition duration-150"
        >
          <i class="fas fa-file-import text-xs"></i> Run Bulk Import
        </button>
      </div>
    </form>

  </div>
</div>

<%- include('../layouts/footer') %>