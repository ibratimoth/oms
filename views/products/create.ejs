<%- include('../layouts/header') %>

<!-- Quick Navigation Escape Route -->
<div class="mb-4">
  <a 
    href="/products" 
    class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-brand-teal transition duration-150 group"
  >
    <i class="fas fa-arrow-left text-xs group-hover:-translate-x-0.5 transition-transform duration-150"></i>
    <span>Back to Products List</span>
  </a>
</div>

<!-- Form Header Title -->
<div class="mb-6">
  <h1 class="text-2xl font-bold tracking-tight text-slate-800">Add New Product</h1>
  <p class="text-sm text-slate-500 mt-1">Register a new stock item in the inventory management ledger.</p>
</div>

<!-- Main Form Container Card -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden max-w-4xl">
  
  <!-- Subtle top accent bar using brand teal -->
  <div class="h-1.5 bg-brand-teal w-full"></div>

  <form method="POST" action="/products/create" class="p-6 sm:p-8 space-y-6">
    
    <!-- SECTION 1: BASIC DETAILS -->
    <div>
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Basic Information</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        
        <!-- Product Name (Full Width on Mobile) -->
        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Product Name</label>
          <input 
            type="text" 
            name="name" 
            required 
            class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 px-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
            placeholder="e.g., Enterprise Wireless Router"
          >
        </div>

      </div>
    </div>

    <!-- Divider Line -->
    <div class="border-t border-slate-100 my-6"></div>

    <!-- SECTION 2: PRICING & STOCK -->
    <div>
      <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Pricing & Inventory Management</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-5">
        
        <!-- Buy Price -->
        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Cost Price (Buy)</label>
          <div class="relative shadow-sm rounded-lg">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-xs font-semibold text-slate-400 bg-slate-100/80 border-r border-slate-200/60 rounded-l-lg px-2">
              TSh
            </span>
            <input 
              type="number" 
              step="0.01" 
              name="buy_price" 
              required 
              class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 pl-12 pr-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
              placeholder="0.00"
            >
          </div>
        </div>

        <!-- Sell Price -->
        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Selling Price</label>
          <div class="relative shadow-sm rounded-lg">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-xs font-semibold text-slate-400 bg-slate-100/80 border-r border-slate-200/60 rounded-l-lg px-2">
              TSh
            </span>
            <input 
              type="number" 
              step="0.01" 
              name="sell_price" 
              required 
              class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 pl-12 pr-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
              placeholder="0.00"
            >
          </div>
        </div>

        <!-- Quantity in Stock -->
        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Initial Stock Qty</label>
          <input 
            type="number" 
            name="quantity_in_stock" 
            required 
            class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 px-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
            placeholder="0"
          >
        </div>

        <!-- Reorder Level -->
        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide mb-1.5">Low Stock Limit</label>
          <input 
            type="number" 
            name="reorder_level" 
            class="w-full bg-slate-50 border border-slate-200 rounded-lg py-2.5 px-3.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 focus:border-brand-teal focus:bg-white transition duration-150" 
            placeholder="5"
          >
        </div>

      </div>
    </div>

    <!-- Form Footer Action Controls -->
    <div class="pt-4 border-t border-slate-100 flex items-center justify-end gap-3">
      <!-- Upgraded explicit exit action link button -->
      <a 
        href="/products" 
        class="px-4 py-2.5 text-sm font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg border border-slate-200 shadow-sm transition duration-150"
      >
        Cancel & Exit
      </a>
      <button 
        type="submit" 
        class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-brand-gold hover:bg-brand-goldHover text-white text-sm font-semibold rounded-lg shadow-sm shadow-brand-gold/10 transition duration-150"
      >
        <i class="fas fa-save text-xs"></i> Save Product
      </button>
    </div>

  </form>
</div>

<%- include('../layouts/footer') %>